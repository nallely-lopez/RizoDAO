# =============================================================================
# RIZO APP — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are bundled into client-side JavaScript
# and are visible to end users. Never put secrets in NEXT_PUBLIC_ variables.
# =============================================================================


# =============================================================================
# DATABASE
# =============================================================================

# Neon PostgreSQL connection string (production).
# Get it from: https://console.neon.tech → your project → Connection Details
# For local development with Docker, use: postgresql://rizo:password@localhost:5432/rizodb
DATABASE_URL=""


# =============================================================================
# AUTH — NextAuth.js
# =============================================================================

# Random secret used to sign and encrypt JWT session tokens.
# Generate one with: openssl rand -base64 32
# Minimum 32 characters required in production.
NEXTAUTH_SECRET=""

# Canonical base URL of your deployment. Used by NextAuth for OAuth callbacks.
# Local development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"


# =============================================================================
# PRIVY — Wallet & Social Login
# =============================================================================

# Privy app ID that enables embedded Stellar wallets + Google/email social login.
# Get it from: https://dashboard.privy.io → your app → App ID
# This value is safe to expose to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_PRIVY_APP_ID=""


# =============================================================================
# ACCESLY — Stellar Wallet Integration
# =============================================================================

# Accesly app ID for the alternative Stellar wallet provider.
# Get it from: https://accesly.dev → your project → App ID
# This value is safe to expose to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_ACCESLY_APP_ID=""


# =============================================================================
# STELLAR NETWORK
# =============================================================================

# Target Stellar network. Use "testnet" for development and "mainnet" for production.
# Switching to mainnet also requires updating STELLAR_HORIZON_URL.
STELLAR_NETWORK="testnet"

# Stellar Horizon REST API endpoint. Horizon is used for submitting transactions
# and querying account balances/history.
# Testnet:  https://horizon-testnet.stellar.org
# Mainnet:  https://horizon.stellar.org
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# Ticker symbol for the RIZO loyalty token issued on Stellar.
# Must match what was used when the issuer account established the asset.
STELLAR_ASSET_CODE="RIZO"


# =============================================================================
# STELLAR ISSUER KEYPAIR  —  ⚠️ SENSITIVE — NEVER COMMIT
# =============================================================================

# The Stellar account that issues RIZO tokens to users and signs loyalty
# contract transactions. Generate a keypair at:
# https://laboratory.stellar.org/#account-creator?network=test
#
# After generating, fund the account on testnet with Friendbot:
# https://friendbot.stellar.org/?addr=<YOUR_PUBLIC_KEY>
#
# Then establish a trustline and create the RIZO asset via the Lab.
STELLAR_ISSUER_PUBLIC_KEY=""
STELLAR_ISSUER_SECRET_KEY=""


# =============================================================================
# STELLAR ENCRYPTION KEY  —  ⚠️ SENSITIVE — NEVER COMMIT
# =============================================================================

# 32-character key used to encrypt users' Stellar secret keys at rest in
# PostgreSQL with AES-256-GCM (see lib/encryption.ts).
# Generate one with: openssl rand -base64 24 | cut -c1-32
# Must be exactly 32 characters.
STELLAR_ENCRYPTION_KEY=""


# =============================================================================
# RIZO STORE WALLET  (public key — safe to expose)
# =============================================================================

# Public Stellar address of the RIZO store wallet that receives USDC payments
# when users make purchases. This address must have a USDC trustline on testnet.
# Falls back to STELLAR_ISSUER_PUBLIC_KEY if not set.
NEXT_PUBLIC_RIZO_WALLET_ADDRESS=""


# =============================================================================
# SOROBAN LOYALTY CONTRACT
# =============================================================================

# Soroban smart contract ID for the RizoLoyalty contract deployed on Stellar.
# Used server-side to call register_purchase() and expire_tokens().
# Deploy the contract with: stellar contract deploy (see contracts/rizo-loyalty/)
LOYALTY_CONTRACT_ID=""

# Same contract ID exposed to the browser for read-only queries
# such as get_balance() and check_discount(). Must match LOYALTY_CONTRACT_ID.
NEXT_PUBLIC_LOYALTY_CONTRACT_ID=""


# =============================================================================
# DOCKER — Local Development Only
# =============================================================================

# These variables are used by docker-compose.yml to spin up a local PostgreSQL
# instance. They are NOT used by the Next.js app directly; the app always reads
# DATABASE_URL. Only needed if you run: docker compose up -d
POSTGRES_USER="rizo"
POSTGRES_PASSWORD=""
POSTGRES_DB="rizodb"
